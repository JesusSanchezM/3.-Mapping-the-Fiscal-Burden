    "# =====================================================\n",
    "# BLOQUE 3\n",
    "# MERGE Y CONCATENAR AÑOS\n",
    "# =====================================================\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "all_years = []\n",
    "\n",
    "for year in YEARS:\n",
    "\n",
    "    print(\"\\n========================\")\n",
    "    print(f\"Building dataset {year}\")\n",
    "    print(\"========================\")\n",
    "\n",
    "    # -----------------------------\n",
    "    # LOAD POBLACION\n",
    "    # -----------------------------\n",
    "\n",
    "    df_pob = pd.read_csv(\n",
    "        RAW_DIR / f\"poblacion_{year}.csv\",\n",
    "        dtype=ID_TYPES,\n",
    "        low_memory=False\n",
    "    )\n",
    "\n",
    "    df_pob = df_pob[\n",
    "        POBLACION_COLUMNS\n",
    "    ].copy()\n",
    "\n",
    "    print(\"Population rows:\", len(df_pob))\n",
    "\n",
    "    # -----------------------------\n",
    "    # LOAD HOGAR\n",
    "    # -----------------------------\n",
    "\n",
    "    df_hog = pd.read_csv(\n",
    "        RAW_DIR / f\"concentradohogar_{year}.csv\",\n",
    "        dtype=ID_TYPES,\n",
    "        low_memory=False\n",
    "    )\n",
    "\n",
    "    df_hog = df_hog[\n",
    "        HOGAR_COLUMNS\n",
    "    ].copy()\n",
    "\n",
    "    print(\"Households rows:\", len(df_hog))\n",
    "\n",
    "    # -----------------------------\n",
    "    # MERGE HOGAR → PERSONA\n",
    "    # -----------------------------\n",
    "\n",
    "    df_pob = df_pob.merge(\n",
    "        df_hog,\n",
    "        on=[\n",
    "            \"folioviv\",\n",
    "            \"foliohog\"\n",
    "        ],\n",
    "        how=\"left\"\n",
    "    )\n",
    "\n",
    "    # -----------------------------\n",
    "    # LOAD INCOME\n",
    "    # -----------------------------\n",
    "\n",
    "    df_income = pd.read_csv(\n",
    "        PROCESSED_DIR\n",
    "        / f\"income_calculated_{year}.csv\",\n",
    "        dtype=ID_TYPES,\n",
    "        low_memory=False\n",
    "    )\n",
    "\n",
    "    # -----------------------------\n",
    "    # MERGE INCOME\n",
    "    # -----------------------------\n",
    "\n",
    "    df_year = df_pob.merge(\n",
    "        df_income,\n",
    "        on=[\n",
    "            \"folioviv\",\n",
    "            \"foliohog\",\n",
    "            \"numren\"\n",
    "        ],\n",
    "        how=\"left\"\n",
    "    )\n",
    "\n",
    "    # -----------------------------\n",
    "    # ADD YEAR\n",
    "    # -----------------------------\n",
    "\n",
    "    df_year[\"year\"] = year\n",
    "\n",
    "    # -----------------------------\n",
    "    # DIAGNOSTICS\n",
    "    # -----------------------------\n",
    "\n",
    "    print(\"\\nDiagnostics\")\n",
    "\n",
    "    print(\n",
    "        \"Missing weights:\",\n",
    "        df_year[\"factor\"].isna().sum()\n",
    "    )\n",
    "\n",
    "    print(\n",
    "        \"Missing income:\",\n",
    "        df_year[\"market_income\"].isna().sum()\n",
    "    )\n",
    "\n",
    "    all_years.append(df_year)\n",
    "\n",
    "# -----------------------------------------------------\n",
    "# CONCAT\n",
    "# -----------------------------------------------------\n",
    "\n",
    "df_final = pd.concat(\n",
    "    all_years,\n",
    "    axis=0,\n",
    "    ignore_index=True\n",
    ")\n",
    "\n",
    "print(\"\\nFinal size:\")\n",
    "\n",
    "print(len(df_final))\n",
    "\n",
    "print(\"\\nYears distribution:\")\n",
    "\n",
    "print(\n",
    "    df_final[\"year\"].value_counts()\n",
    ")\n",
    "\n",
    "# -----------------------------------------------------\n",
    "# EXPORT\n",
    "# -----------------------------------------------------\n",
    "\n",
    "output_file = (\n",
    "    PROCESSED_DIR\n",
    "    / \"net_market_and_market_income.csv\"\n",
    ")\n",
    "\n",
    "df_final.to_csv(\n",
    "    output_file,\n",
    "    index=False\n",
    ")\n",
    "\n",
    "print(\"\\nSaved file:\")\n",
    "\n",
    "print(output_file.name)"
   ]
