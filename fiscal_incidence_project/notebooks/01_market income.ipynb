    "# =====================================================\n",
    "# BLOQUE 1\n",
    "# CALCULAR MARKET INCOME\n",
    "# =====================================================\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "for year in YEARS:\n",
    "\n",
    "    print(\"\\n========================\")\n",
    "    print(f\"Processing income {year}\")\n",
    "    print(\"========================\")\n",
    "\n",
    "    # -----------------------------\n",
    "    # LOAD INGRESOS\n",
    "    # -----------------------------\n",
    "\n",
    "    file_ing = RAW_DIR / f\"ingresos_{year}.csv\"\n",
    "\n",
    "    df_ing = pd.read_csv(\n",
    "        file_ing,\n",
    "        dtype={\n",
    "            \"folioviv\": \"string\",\n",
    "            \"foliohog\": \"string\",\n",
    "            \"numren\": \"int64\"\n",
    "        },\n",
    "        low_memory=False\n",
    "    )\n",
    "\n",
    "    print(\"Rows:\", len(df_ing))\n",
    "\n",
    "    # -----------------------------\n",
    "    # KEEP LABOR INCOME\n",
    "    # -----------------------------\n",
    "\n",
    "    df_ing = df_ing[\n",
    "        df_ing[\"clave\"] == \"P001\"\n",
    "    ].copy()\n",
    "\n",
    "    print(\"Labor income rows:\", len(df_ing))\n",
    "\n",
    "    # -----------------------------\n",
    "    # RENAME NET INCOME\n",
    "    # -----------------------------\n",
    "\n",
    "    df_ing = df_ing.rename(\n",
    "        columns={\n",
    "            \"ing_tri\": \"net_market_income\"\n",
    "        }\n",
    "    )\n",
    "\n",
    "    # -----------------------------\n",
    "    # CALCULATE MARKET INCOME\n",
    "    # -----------------------------\n",
    "\n",
    "    brackets = TAX_BRACKETS[year]\n",
    "\n",
    "    df_ing = calculate_market_income(\n",
    "        df_ing,\n",
    "        brackets\n",
    "    )\n",
    "\n",
    "    # -----------------------------\n",
    "    # KEEP ONLY NECESSARY COLUMNS\n",
    "    # -----------------------------\n",
    "\n",
    "    df_income = df_ing[\n",
    "        [\n",
    "            \"folioviv\",\n",
    "            \"foliohog\",\n",
    "            \"numren\",\n",
    "            \"market_income\",\n",
    "            \"net_market_income\"\n",
    "        ]\n",
    "    ].copy()\n",
    "\n",
    "    # -----------------------------\n",
    "    # DIAGNOSTICS\n",
    "    # -----------------------------\n",
    "\n",
    "    print(\"\\nIncome summary\")\n",
    "\n",
    "    print(\n",
    "        df_income[\n",
    "            [\n",
    "                \"market_income\",\n",
    "                \"net_market_income\"\n",
    "            ]\n",
    "        ].describe()\n",
    "    )\n",
    "\n",
    "    # -----------------------------\n",
    "    # SAVE\n",
    "    # -----------------------------\n",
    "\n",
    "    output_file = (\n",
    "        PROCESSED_DIR\n",
    "        / f\"income_calculated_{year}.csv\"\n",
    "    )\n",
    "\n",
    "    df_income.to_csv(\n",
    "        output_file,\n",
    "        index=False\n",
    "    )\n",
    "\n",
    "    print(\"\\nSaved:\")\n",
    "\n",
    "    print(output_file.name)"
   ]
