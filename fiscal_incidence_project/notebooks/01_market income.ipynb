    "# -----------------------------------------------------\n",
    "# FUNCTION: GROSS-UP CALCULATION\n",
    "# -----------------------------------------------------"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "39869f43",
   "metadata": {},
   "outputs": [],
   "source": [
    "# -----------------------------------------------------\n",
    "# FUNCTION: GROSS-UP CALCULATION\n",
    "# -----------------------------------------------------\n",
    "\n",
    "def calculate_market_income(df, brackets):\n",
    "\n",
    "    df[\"market_income\"] = np.nan\n",
    "\n",
    "    for b in brackets:\n",
    "\n",
    "        gross_temp = (\n",
    "            df[\"net_market_income\"]\n",
    "            + b[\"cf\"]\n",
    "            - b[\"tm\"] * b[\"li\"]\n",
    "        ) / (1 - b[\"tm\"])\n",
    "\n",
    "        mask = (\n",
    "            df[\"market_income\"].isna()\n",
    "        ) & (\n",
    "            gross_temp >= b[\"li\"]\n",
    "        ) & (\n",
    "            gross_temp <= b[\"ls\"]\n",
    "        )\n",
    "\n",
    "        df.loc[mask, \"market_income\"] = gross_temp\n",
    "\n",
    "    return df"
   ]
  },
